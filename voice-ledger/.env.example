# ══════════════════════════════════════════════════════════════════════
#  Voice Ledger — Environment Variables
#  Copy to .env and add ONE API key. App works with any of the three.
# ══════════════════════════════════════════════════════════════════════

# ── OPTION A: Google Gemini (RECOMMENDED — completely free) ────────────
# Step 1: Go to https://aistudio.google.com
# Step 2: Sign in with your Google account (Gmail)
# Step 3: Click "Get API key" → "Create API key"
# Step 4: Copy and paste below
# Cost: $0 forever (free tier: 15 req/min, 1M tokens/day)
GOOGLE_API_KEY=

# ── OPTION B: Groq (free — if you can sign up) ────────────────────────
# Step 1: Go to https://console.groq.com
# Step 2: Sign up → API Keys → Create
# Cost: $0 forever (14,400 req/day)
GROQ_API_KEY=

# ── OPTION C: OpenAI (paid) ────────────────────────────────────────────
# Only use this if you specifically want GPT-4
# Cost: ~$3-5/month
OPENAI_API_KEY=

# ── Leave these as defaults ────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GROQ_LLM_MODEL=llama-3.1-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
DATABASE_URL=sqlite:///./voice_ledger.db
CHROMA_PERSIST_DIR=./chroma_db
MLFLOW_TRACKING_URI=./mlruns
